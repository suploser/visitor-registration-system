/* 首页样式 */
.page-index {
  min-height: 100vh;
  background: #f5f5f5;
}

/* === 背景图区域 === */
.hero-section {
  width: 100%;
  height: 420rpx;
  position: relative;
  overflow: hidden;
  /* CSS渐变回退（无图片时显示） */
  background: linear-gradient(135deg, #1a73e8 0%, #1557b0 40%, #0d47a1 100%);
}

.hero-bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.35);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.hero-overlay.no-image {
  /* 无背景图时降低遮罩透明度 */
  background: rgba(0, 0, 0, 0.15);
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 4rpx;
}

.hero-subtitle {
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* === 滚动图片区 === */
.gallery-section {
  position: relative;
  z-index: 10;
  background: #fff;
  margin: -50rpx 24rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 -6rpx 24rpx rgba(0, 0, 0, 0.08), 0 10rpx 32rpx rgba(0, 0, 0, 0.12);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding: 30rpx 30rpx 16rpx;
}

.gallery-swiper {
  width: 100%;
  height: 210rpx;
}

.gallery-scroll {
  white-space: nowrap;
  padding: 0 30rpx 36rpx;
}

.gallery-item-wrap {
  padding: 0 10rpx;
  height: 100%;
  box-sizing: border-box;
}

.gallery-item {
  display: block;
  width: 100%;
  height: 180rpx;
  border-radius: 14rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.15);
}

.gallery-image {
  width: 100%;
  height: 100%;
}

.gallery-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8rpx 16rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  color: #fff;
  font-size: 22rpx;
  text-align: center;
}

/* 占位卡片 */
.gallery-placeholder {
  background: #f0f4ff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.placeholder-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
}

.placeholder-icon {
  font-size: 56rpx;
  margin-bottom: 8rpx;
}

.placeholder-text {
  font-size: 22rpx;
  opacity: 0.9;
}

/* === 快捷操作 === */
.action-section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 20rpx 30rpx;
}

.action-item {
  width: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  transition: transform 0.15s;
}

.action-item:active {
  transform: scale(0.96);
}

.action-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.icon-register { background: #e8f5e9; }
.icon-result { background: #e3f2fd; }
.icon-approval { background: #fff3e0; }
.icon-history { background: #f3e5f5; }

.action-label {
  font-size: 26rpx;
  color: #333;
}

/* === 欢迎弹窗 === */
.welcome-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  padding: 10rpx 0;
  text-align: center;
}
