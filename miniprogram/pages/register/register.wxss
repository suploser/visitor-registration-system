/* 登记页样式 */
.page-register {
  min-height: 100vh;
  background: #f5f5f5;
  width: 100%;
  overflow-x: hidden;
  box-sizing: border-box;
}

.form-scroll {
  width: 100%;
  padding: 20rpx;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a73e8;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #e8e8e8;
}

.switch-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 10rpx 0;
}

.companion-item {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.companion-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.companion-del {
  color: #e74c3c;
  font-size: 26rpx;
}

.submit-section {
  padding: 30rpx 0;
}
