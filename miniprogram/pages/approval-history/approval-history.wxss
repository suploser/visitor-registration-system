/* 审批记录页样式 */
.page-approval-history {
  min-height: 100vh;
  background: #f5f5f5;
}

.header-bar {
  padding: 24rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
}

.list-container {
  padding: 20rpx;
}

.record-card {
  padding: 24rpx 30rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.visitor-name {
  font-size: 30rpx;
  font-weight: 600;
}

.record-info {
  margin-bottom: 12rpx;
}

.info-row {
  font-size: 26rpx;
  color: #555;
  padding: 4rpx 0;
}

.info-label {
  color: #999;
}

.record-comment {
  font-size: 26rpx;
  color: #666;
  padding: 10rpx 0;
  border-top: 1rpx solid #f5f5f5;
}

.comment-label {
  color: #999;
}

.record-time {
  font-size: 24rpx;
  color: #bbb;
  text-align: right;
}
