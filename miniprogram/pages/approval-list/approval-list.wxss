/* 待审批列表样式 */
.page-approval-list {
  min-height: 100vh;
  background: #f5f5f5;
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
}

.header-role {
  font-size: 24rpx;
  color: #1a73e8;
  background: #e8f0fe;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.list-container {
  padding: 20rpx;
}

.approval-card {
  position: relative;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.visitor-name {
  font-size: 32rpx;
  font-weight: 600;
}

.card-info {
  margin-bottom: 12rpx;
}

.info-row {
  display: flex;
  padding: 8rpx 0;
  font-size: 26rpx;
  color: #555;
}

.info-label {
  color: #999;
  width: 150rpx;
  flex-shrink: 0;
}

.card-arrow {
  text-align: right;
  color: #1a73e8;
  font-size: 28rpx;
}
